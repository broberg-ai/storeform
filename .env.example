# Copy to .env (gitignored) and fill in. NEVER commit real secrets.

# Upmetrics error/incident tracking (F001.1). DSN is public; API key is secret.
UPMETRICS_DSN=
UPMETRICS_API_KEY=

# Discovery reuse-inventory self-enroll key. Generate once: openssl rand -hex 32
DISCOVERY_ENROLL_KEY=

# Cloud Lens (F001.3 — real App Store Connect / Google Play runs).
# Provisioned by cardmem (Fly-secret or Vault). Local test-form runs need neither.
LENS_CLOUD_URL=https://lens.cardmem.com
LENS_CLOUD_TOKEN=
