# Copy to .env (gitignored) and fill in. NEVER commit real secrets.

# Upmetrics error/incident tracking (F001.1). DSN is public; API key is secret.
UPMETRICS_DSN=
UPMETRICS_API_KEY=

# Discovery reuse-inventory self-enroll key. Generate once: openssl rand -hex 32
DISCOVERY_ENROLL_KEY=

# Cloud Lens (F001.3 — real App Store Connect / Google Play runs).
# Provisioned by cardmem (Fly-secret or Vault). Local test-form runs need neither.
LENS_CLOUD_URL=https://lens.cardmem.com
LENS_CLOUD_TOKEN=

# Graceful-fail (F001.8): when a locator chain runs dry, StoreForm posts a
# "needs review" item into this project's cardmem Inbox. Ship-dark without the key.
# Mint the key via cardmem_generate_inbox_webhook_key. Secret → .env only.
STOREFORM_CARDMEM_INBOX_URL=https://cardmem.com/api/board/idea
STOREFORM_CARDMEM_INBOX_KEY=

# Optional generic failure webhook (e.g. a Buddycloud endpoint). Ship-dark if unset.
STOREFORM_NOTIFY_WEBHOOK=
